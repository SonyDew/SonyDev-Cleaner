<Window x:Class="SonyDevCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SonyDev Cleaner"
        Width="1440"
        Height="900"
        MinWidth="1280"
        MinHeight="820"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Border CornerRadius="20" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#CC000018" BlurRadius="50" ShadowDepth="10" Direction="270" Opacity="0.8" />
        </Border.Effect>

        <Grid>
            <Rectangle Fill="#FF050510" />

            <Canvas ClipToBounds="True" IsHitTestVisible="False">
                <Ellipse Width="920" Height="920" Canvas.Left="-280" Canvas.Top="-340" Opacity="0.52">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF3D6FFF" Offset="0" />
                            <GradientStop Color="#001040FF" Offset="0.7" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="70" KernelType="Gaussian" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="840" Height="840" Canvas.Right="-180" Canvas.Top="-260" Opacity="0.56">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFA040FF" Offset="0" />
                            <GradientStop Color="#006010B0" Offset="0.65" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="80" KernelType="Gaussian" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="760" Height="760" Canvas.Left="620" Canvas.Bottom="-260" Opacity="0.38">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF10C8A0" Offset="0" />
                            <GradientStop Color="#000890A0" Offset="0.65" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="65" KernelType="Gaussian" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="600" Height="600" Canvas.Left="-120" Canvas.Bottom="-180" Opacity="0.28">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFF5090" Offset="0" />
                            <GradientStop Color="#00FF0040" Offset="0.65" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="55" KernelType="Gaussian" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="480" Height="420" Canvas.Left="520" Canvas.Top="220" Opacity="0.18">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF5A5AFF" Offset="0" />
                            <GradientStop Color="#00000080" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="50" KernelType="Gaussian" />
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#10FFFFFF"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0" />
                            <GradientStop Color="#25FFFFFF" Offset="0.5" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>

                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="22" Height="22">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF5E8AFF" Offset="0" />
                                        <GradientStop Color="#FFA855F7" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#885E8AFF" BlurRadius="10" ShadowDepth="0" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="SonyDev Cleaner"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#E0FFFFFF" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnMinimize" Click="BtnMinimize_Click" Width="32" Height="32" Cursor="Hand" ToolTip="Minimize">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="Bg" Width="32" Height="32" Fill="#20FFFFFF" />
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Fill" Value="#40FFD060" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="—" FontFamily="Segoe UI Symbol" FontSize="13"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                            <Button x:Name="BtnMaximize" Margin="8,0,0,0" Click="BtnMaximize_Click" Width="32" Height="32" Cursor="Hand" ToolTip="Maximize">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="Bg" Width="32" Height="32" Fill="#20FFFFFF" />
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Fill" Value="#4050C050" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="□" FontFamily="Segoe UI Symbol" FontSize="13"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                            <Button x:Name="BtnClose" Margin="8,0,0,0" Click="BtnClose_Click" Width="32" Height="32" Cursor="Hand" ToolTip="Close">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="Bg" Width="32" Height="32" Fill="#20FFFFFF" />
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Fill" Value="#50FF4455" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="✕" FontFamily="Segoe UI Symbol" FontSize="13"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="16,12,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource GlassPanel}" ClipToBounds="True">
                        <Grid Margin="12,20,12,20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource GlassPanel}" Padding="16,14" CornerRadius="16" Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="SONYDEV UTILS" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                                    <TextBlock Margin="0,8,0,0" Text="Cleaner" FontFamily="Bahnschrift" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock x:Name="SidebarSubtitleText" Margin="0,6,0,0" Text="Safe cleanup dashboard with glass navigation and sectioned pages." TextWrapping="Wrap" FontSize="12.5" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="1">
                                <TextBlock Margin="8,0,0,8" Text="NAVIGATION" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}" />
                                <Button x:Name="HomeNavButton" Style="{StaticResource NavButton}" Margin="0,2" Click="HomeNavButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⌂" FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Symbol, Segoe UI" />
                                        <TextBlock Text="Home" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="CleanupNavButton" Style="{StaticResource NavButton}" Margin="0,2" Click="CleanupNavButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="✦" FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Symbol, Segoe UI" />
                                        <TextBlock Text="Safe Cleanup" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="LargeFilesNavButton" Style="{StaticResource NavButton}" Margin="0,2" Click="LargeFilesNavButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="◈" FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Symbol, Segoe UI" />
                                        <TextBlock Text="Large Files" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ActivityNavButton" Style="{StaticResource NavButton}" Margin="0,2" Click="ActivityNavButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="≡" FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Symbol, Segoe UI" />
                                        <TextBlock Text="Activity" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="StartupNavButton" Style="{StaticResource NavButton}" Margin="0,2" Click="StartupNavButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⚡" FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Symbol, Segoe UI" />
                                        <TextBlock Text="Startup Apps" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="DiskUsageNavButton" Style="{StaticResource NavButton}" Margin="0,2" Click="DiskUsageNavButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="◉" FontSize="14" Width="18" TextAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Symbol, Segoe UI" />
                                        <TextBlock Text="Disk Usage" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Border Grid.Row="2" Style="{StaticResource GlassPanel}" Padding="12,10" CornerRadius="12">
                                <StackPanel>
                                    <TextBlock x:Name="SidebarModeText" Text="Standard mode" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock x:Name="SidebarLogCountText" Margin="0,4,0,0" Text="0 log entries" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <ContentControl x:Name="PageContentHost" Grid.Column="2" />
                </Grid>

                <Border Grid.Row="2"
                        HorizontalAlignment="Center"
                        Margin="0,5,0,10"
                        Padding="16,0"
                        Height="34"
                        MinWidth="200"
                        CornerRadius="10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#22FFFFFF" Offset="0"/>
                            <GradientStop Color="#12FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#35FFFFFF" Offset="0"/>
                            <GradientStop Color="#10FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <TextBlock x:Name="StatusLabel"
                               Foreground="#AAD0D8F0"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
