<UserControl x:Class="SonyDevCleaner.App.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,6">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="18,14" Margin="6">
                    <StackPanel>
                        <TextBlock Text="RECLAIMABLE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                        <TextBlock x:Name="ReclaimableValueText" Margin="0,10,0,0" FontFamily="Bahnschrift" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="0 B" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource GlassPanel}" Padding="18,14" Margin="6">
                    <StackPanel>
                        <TextBlock Text="SELECTED" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                        <TextBlock x:Name="SelectedValueText" Margin="0,10,0,0" FontFamily="Bahnschrift" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="0 B" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource GlassPanel}" Padding="18,14" Margin="6">
                    <StackPanel>
                        <TextBlock Text="CATEGORIES READY" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                        <TextBlock x:Name="ReadyValueText" Margin="0,10,0,0" FontFamily="Bahnschrift" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource GlassPanel}" Padding="18,14" Margin="6">
                    <StackPanel>
                        <TextBlock Text="MODE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                        <TextBlock x:Name="ModeValueText" Margin="0,10,0,0" FontFamily="Bahnschrift" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="Standard" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource GlassPanel}"
                    Margin="6,0,6,12"
                    Padding="20,0"
                    Height="70">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="CLEANED THIS MONTH"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#66B0C0D8"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"/>
                        <TextBlock x:Name="StatMonthLabel"
                                   Margin="0,3,0,0"
                                   Text="—"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="TOTAL CLEANED"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#66B0C0D8"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"/>
                        <TextBlock x:Name="StatTotalLabel"
                                   Margin="0,3,0,0"
                                   Text="—"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="RUNS THIS MONTH"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#66B0C0D8"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"/>
                        <TextBlock x:Name="StatRunsLabel"
                                   Margin="0,3,0,0"
                                   Text="—"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                        <TextBlock Text="LAST CLEAN"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="#66B0C0D8"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"/>
                        <TextBlock x:Name="StatLastLabel"
                                   Margin="0,3,0,0"
                                   Text="—"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource GlassPanel}"
                    Margin="6,0,6,12"
                    Padding="20,0"
                    Height="52">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Weekly automatic scan"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock x:Name="ScheduleStatusLabel"
                                   Margin="0,2,0,0"
                                   Text="Checking..."
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="11"
                                   Foreground="#66D0D8F0" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="ScheduleToggleButton"
                            Style="{StaticResource GlassButton}"
                            Height="32"
                            Padding="16,0"
                            VerticalAlignment="Center"
                            Click="ScheduleToggle_Click"
                            Content="Enable" />
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="18" Margin="6">
                <Grid VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Control Center" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Run a scan first, then jump into cleanup, large file analysis or activity." TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RunScanButton" Grid.Column="0" Style="{StaticResource AccentButton}" Content="Run Scan" />
                        <Button x:Name="OpenCleanupButton" Grid.Column="2" Style="{StaticResource GlassButton}" Content="Open Cleanup" />
                    </Grid>
                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                x:Name="FlushDnsButton"
                                Style="{StaticResource GlassButton}"
                                Height="36"
                                Padding="14,0"
                                Margin="0,0,6,0"
                                Click="FlushDns_Click">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="Flush DNS Cache" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Grid.Column="1"
                                x:Name="EmptyBinButton"
                                Style="{StaticResource GlassButton}"
                                Height="36"
                                Padding="14,0"
                                Margin="6,0,0,0"
                                Click="EmptyBin_Click">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🗑" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="Empty Recycle Bin" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource GlassPanel}" Padding="18" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recent Activity" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Grid.Row="1" Margin="0,8,0,12" Text="Latest log entries mirrored from the activity page." TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <RichTextBox x:Name="RecentActivityTextBox"
                                 Grid.Row="2"
                                 VerticalAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Padding="18" Margin="6">
                <Grid VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Modules" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Cleaner workflow split into focused sections." TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="SelectionInfoText" Grid.Row="2" Margin="0,18,0,6" Text="Selection progress" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <Grid x:Name="SelectionTrack" Grid.Row="3" Height="6" Margin="0,4,0,0">
                        <Border CornerRadius="3" Background="#25FFFFFF"/>
                        <Border x:Name="SelectionFill" CornerRadius="3" HorizontalAlignment="Left" Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF5E8AFF" Offset="0"/>
                                    <GradientStop Color="#FFA855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="ReadyInfoText" Grid.Row="4" Margin="0,18,0,6" Text="Categories ready" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <Grid x:Name="CategoriesTrack" Grid.Row="5" Height="6" Margin="0,4,0,0">
                        <Border CornerRadius="3" Background="#25FFFFFF"/>
                        <Border x:Name="CategoriesFill" CornerRadius="3" HorizontalAlignment="Left" Width="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF2DD4BF" Offset="0"/>
                                    <GradientStop Color="#FF5E8AFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="6" Margin="0,18,0,0" Text="Large Files and Activity stay separated so cleanup actions remain clear and safe." TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource GlassPanel}" Padding="18" Margin="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Safety Notes" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Grid.Row="1" Margin="0,8,0,12" Text="What this cleaner does and what it intentionally avoids." TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Grid.Row="2"
                               Text="- Preview-first cleanup only.&#x0a;&#x0a;- No registry cleaner or hidden tweaks.&#x0a;&#x0a;- Restricted folders stay visible so you know what requires elevation.&#x0a;&#x0a;- Large Files analyzes only and never deletes automatically."
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
