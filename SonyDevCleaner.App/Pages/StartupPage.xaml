<UserControl x:Class="SonyDevCleaner.App.Pages.StartupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Startup Manager"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       FontFamily="Segoe UI Variable Display, Segoe UI" />
            <TextBlock Margin="0,3,0,0"
                       Text="Programs that run automatically when Windows starts."
                       FontSize="12"
                       Foreground="#88D0D8F0"
                       FontFamily="Segoe UI Variable Text, Segoe UI" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource GlassPanel}"
                    Padding="0"
                    Margin="0,0,6,0">
                <Border x:Name="StartupGridClipHost"
                        CornerRadius="16"
                        Background="Transparent"
                        BorderThickness="0">
                    <Border.OpacityMask>
                        <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                            <VisualBrush.Visual>
                                <Border Background="Black"
                                        CornerRadius="16"
                                        Width="{Binding ActualWidth, ElementName=StartupGridClipHost}"
                                        Height="{Binding ActualHeight, ElementName=StartupGridClipHost}" />
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>
                    <Grid>
                        <Border Height="36"
                                VerticalAlignment="Top"
                                Background="#12FFFFFF"
                                BorderBrush="#18FFFFFF"
                                BorderThickness="0,0,0,1"
                                CornerRadius="16,16,0,0"
                                IsHitTestVisible="False" />
                        <DataGrid x:Name="StartupGrid"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Margin="0"
                                  Style="{StaticResource GlassDataGrid}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Enabled" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Enabled}"
                                                      IsEnabled="False"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" />
                                <DataGridTextColumn Header="Publisher" Binding="{Binding Publisher}" Width="180" />
                                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="ToolTip" Value="{Binding Location}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#CCD0D8F0"/>
                                            <Setter Property="FontSize" Value="11.5"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="ToolTip" Value="{Binding Type}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="LoadingText"
                                   Text="Loading..."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </Grid>
                </Border>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource GlassPanel}"
                    Padding="0"
                    Margin="6,0,0,0">
                <StackPanel Margin="16">
                    <TextBlock Text="Actions"
                               FontSize="14"
                               FontWeight="Bold"
                               Margin="0,0,0,12"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button Content="⏸ Disable selected"
                            Style="{StaticResource GlassButton}"
                            Height="36"
                            Margin="0,0,0,8"
                            Click="DisableStartup_Click" />
                    <Button Content="▶ Enable selected"
                            Style="{StaticResource GlassButton}"
                            Height="36"
                            Margin="0,0,0,16"
                            Click="EnableStartup_Click" />
                    <Border Height="1"
                            Background="#15FFFFFF"
                            Margin="0,0,0,16" />
                    <TextBlock Text="⚠ Disabling startup items does not delete them."
                               Foreground="#88D0D8F0"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Changes take effect on next Windows login."
                               Foreground="#66D0D8F0"
                               FontSize="11"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
