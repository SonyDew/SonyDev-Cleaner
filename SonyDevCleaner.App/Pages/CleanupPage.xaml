<UserControl x:Class="SonyDevCleaner.App.Pages.CleanupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Safe Cleanup"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       FontFamily="Segoe UI Variable Display, Segoe UI" />
            <TextBlock Margin="0,3,0,0"
                       Text="Preview categories first, then choose exactly what to clean."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#88D0D8F0"
                       FontFamily="Segoe UI Variable Text, Segoe UI" />

            <primitives:UniformGrid Columns="3" Rows="1" Height="80" Margin="0,16,0,0">
                <Border Style="{StaticResource GlassPanel}" Padding="16,12" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="AVAILABLE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                        <TextBlock x:Name="AvailableValueText" Margin="0,8,0,0" FontFamily="Bahnschrift" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="0 B" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassPanel}" Padding="16,12" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="SELECTED" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                        <TextBlock x:Name="SelectedValueText" Margin="0,8,0,0" FontFamily="Bahnschrift" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="0 B" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource GlassPanel}" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="READY" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" />
                        <TextBlock x:Name="ReadyValueText" Margin="0,8,0,0" FontFamily="Bahnschrift" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Text="0" />
                    </StackPanel>
                </Border>
            </primitives:UniformGrid>

            <Grid Margin="0,16,0,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ScanButton" Style="{StaticResource GlassButton}" Content="Scan" Width="112" />
                    <Button x:Name="CleanButton" Margin="12,0,0,0" Style="{StaticResource AccentButton}" Content="Clean" Width="128" />
                    <Button x:Name="ElevateButton"
                            Content="⚡ Run as Administrator"
                            Style="{StaticResource GlassButton}"
                            Height="36" Padding="16,0"
                            Margin="12,0,0,0"
                            Visibility="Collapsed"
                            Click="ElevateButton_Click"/>
                    <CheckBox x:Name="SelectAllCheckBox" Margin="12,0,0,0" Style="{StaticResource GlassCheckBox}" Content="Select everything safe" VerticalAlignment="Center" />
                </StackPanel>

                <Button x:Name="ExportButton"
                        Grid.Column="1"
                        Style="{StaticResource GlassButton}"
                        Height="36"
                        Padding="14,0"
                        IsEnabled="False"
                        Click="Export_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="↓" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Export Report" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button.Content>
                </Button>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                <Button x:Name="FilterAll"
                        Content="All"
                        Style="{StaticResource AccentButton}"
                        Height="30"
                        Padding="14,0"
                        Click="Filter_Click"
                        Tag="All" />
                <Button x:Name="FilterReady"
                        Content="Ready"
                        Style="{StaticResource GlassButton}"
                        Height="30"
                        Padding="14,0"
                        Margin="8,0,0,0"
                        Click="Filter_Click"
                        Tag="Ready" />
                <Button x:Name="FilterRestricted"
                        Content="Restricted"
                        Style="{StaticResource GlassButton}"
                        Height="30"
                        Padding="14,0"
                        Margin="8,0,0,0"
                        Click="Filter_Click"
                        Tag="Restricted" />
                <Button x:Name="FilterNothing"
                        Content="Nothing to clean"
                        Style="{StaticResource GlassButton}"
                        Height="30"
                        Padding="14,0"
                        Margin="8,0,0,0"
                        Click="Filter_Click"
                        Tag="Nothing" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource GlassPanel}" Padding="0">
            <Border x:Name="CleanupGridClipHost" CornerRadius="16" Background="Transparent" BorderThickness="0">
                <Border.OpacityMask>
                    <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Top">
                        <VisualBrush.Visual>
                            <Border Background="Black"
                                    CornerRadius="16"
                                    Width="{Binding ActualWidth, ElementName=CleanupGridClipHost}"
                                    Height="{Binding ActualHeight, ElementName=CleanupGridClipHost}" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <Grid>
                    <Border Height="36"
                            VerticalAlignment="Top"
                            Background="#12FFFFFF"
                            BorderBrush="#18FFFFFF"
                            BorderThickness="0,0,0,1"
                            CornerRadius="16,16,0,0"
                            IsHitTestVisible="False" />
                    <DataGrid x:Name="CleanupGrid"
                              Background="Transparent"
                              BorderThickness="0"
                              Margin="0"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource GlassDataGrid}"
                              HeadersVisibility="Column">
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,6,0,4" Background="Transparent">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#88FFFFFF"
                                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                                       FontSize="10"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="56" Header="">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding IsSelectable}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.2*" />
                            <DataGridTextColumn Header="What it cleans" Binding="{Binding Description}" Width="2.7*" />
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="0.8*" />
                            <DataGridTextColumn Header="Files" Binding="{Binding Files}" Width="0.7*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1.5*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid x:Name="BusyOverlay" Visibility="Collapsed"
                          Background="#88000010">
                        <Border CornerRadius="16" Background="#88000010"/>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Style="{StaticResource SpinnerRing}"
                                    Width="52" Height="52"
                                    HorizontalAlignment="Center">
                                <Ellipse Width="52" Height="52"
                                         StrokeThickness="4">
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF5E8AFF" Offset="0"/>
                                            <GradientStop Color="#00A855F7" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                </Ellipse>
                            </Border>
                            <TextBlock x:Name="BusyLabel"
                                       Margin="0,16,0,0"
                                       Text="Scanning..."
                                       Foreground="White"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
